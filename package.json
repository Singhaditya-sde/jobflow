{
  "name": "jobflow",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --filter @jobflow/api dev",
    "dev:worker": "bun run --filter @jobflow/worker dev",
    "dev:dashboard": "bun run --filter @jobflow/dashboard dev",
    "build": "bun run --workspaces build",
    "lint": "bun run --workspaces lint",
    "test": "bun run --workspaces test"
  }
}