{
  "name": "@jobflow/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:delayed": "bun --watch src/delayed.ts",

    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",

    "start": "bun dist/index.js",
    "start:delayed": "bun dist/delayed.js"
  },
  "dependencies": {
    "@jobflow/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
  "@types/express": "^5.0.6",
  "typescript": "^6.0.3"
}
}